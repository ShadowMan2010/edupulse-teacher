<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1800ffff" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Glass body -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E6121218" />
            <stroke
                android:width="1dp"
                android:color="#1500ffff" />
            <corners android:radius="11dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#15ffffff"
                android:endColor="#05000000" />
        </shape>
    </item>
</layer-list>