<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6600E5FF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Accent bar -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00E5FF" />
            <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" />
            <size android:height="2dp" />
        </shape>
    </item>
    <!-- Card body -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#111111" />
            <corners android:bottomLeftRadius="12dp" android:bottomRightRadius="12dp" />
        </shape>
    </item>
</layer-list>