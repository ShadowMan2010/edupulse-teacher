<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0a00ffff" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Gradient accent bar (cyan → purple) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00ffff"
                android:endColor="#7c3aed" />
            <corners android:topLeftRadius="14dp" android:topRightRadius="14dp" />
            <size android:height="3dp" />
        </shape>
    </item>
    <!-- Glass card body -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#D91A1A24" />
            <stroke
                android:width="1dp"
                android:color="#1800ffff" />
            <corners android:bottomLeftRadius="14dp" android:bottomRightRadius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#18ffffff"
                android:endColor="#06000000" />
        </shape>
    </item>
</layer-list>
