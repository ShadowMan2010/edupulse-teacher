<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="#000000">

    <!-- === SPLASH SCREEN === -->
    <FrameLayout
        android:id="@+id/splashContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:background="#000000">

        <com.edupulse.teacher.GlassCardView
            android:id="@+id/splashCard"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:padding="24dp"
            android:elevation="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/splashLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_small"
                    android:contentDescription="@string/app_name"
                    android:alpha="0.95" />

                <TextView
                    android:id="@+id/splashGlitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="EDUPULSE"
                    android:textColor="#EAFFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/splashTeacher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/teacher"
                    android:textColor="#8CFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
            </LinearLayout>
        </com.edupulse.teacher.GlassCardView>
    </FrameLayout>

    <!-- === LOGIN SCREEN === -->
    <FrameLayout
        android:id="@+id/loginContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="40dp">

                <ImageView
                    android:id="@+id/loginLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_small"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/loginGlitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="EDUPULSE"
                    android:textColor="#EAFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/loginTeacherLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/teacher_sign_in"
                    android:textColor="#8CFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="32dp" />

                <com.edupulse.teacher.GlassCardView
                    android:id="@+id/loginCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/emailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="#0AFFFFFF"
                            app:boxStrokeColor="#14FFFFFF"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:hintTextColor="#66FFFFFF"
                            app:endIconMode="none">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/emailField"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:hint="@string/email"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:inputType="textEmailAddress"
                                android:fontFamily="monospace"
                                android:backgroundTint="@android:color/transparent" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/passwordInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="#0AFFFFFF"
                            app:boxStrokeColor="#14FFFFFF"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:hintTextColor="#66FFFFFF"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="#00E5FF">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/passwordField"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:hint="@string/password"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:inputType="textPassword"
                                android:fontFamily="monospace"
                                android:backgroundTint="@android:color/transparent" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/signInButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="@string/sign_in"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:background="@drawable/btn_gradient"
                            android:stateListAnimator="@null"
                            android:elevation="4dp"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.gms.common.SignInButton
                            android:id="@+id/googleSignInButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/loginError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF3B3B"
                            android:textSize="12sp"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.edupulse.teacher.GlassCardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- === CONNECT SCREEN === -->
    <ScrollView
        android:id="@+id/connectContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingVertical="40dp">

            <ImageView
                android:id="@+id/connectLogo"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/logo_small"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connect_to_server"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

            <com.edupulse.teacher.GlassCardView
                android:id="@+id/connectCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/ipInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#0AFFFFFF"
                        app:boxStrokeColor="#14FFFFFF"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:hintTextColor="#66FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/ipField"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="@string/server_ip"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:inputType="text"
                            android:fontFamily="monospace"
                            android:backgroundTint="@android:color/transparent" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/portInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#0AFFFFFF"
                        app:boxStrokeColor="#14FFFFFF"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:hintTextColor="#66FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/portField"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="@string/port"
                            android:text="3000"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:fontFamily="monospace"
                            android:backgroundTint="@android:color/transparent" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/connectButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/connect"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:background="@drawable/btn_gradient"
                        android:stateListAnimator="@null"
                        android:elevation="4dp" />

                    <TextView
                        android:id="@+id/connectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="#8CFFFFFF"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.edupulse.teacher.GlassCardView>
        </LinearLayout>
    </ScrollView>

    <!-- === MAIN SCREEN === -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="gone">

        <!-- Top bar -->
        <com.edupulse.teacher.GlassCardView
            android:id="@+id/topBarCard"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:elevation="8dp"
            app:showTopBarAccent="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/mainLogo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/logo_small"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/userEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/exitButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/exit"
                    android:textColor="#FF3B3B"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:fontFamily="monospace"
                    android:background="@drawable/btn_outline"
                    android:stateListAnimator="@null"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>
        </com.edupulse.teacher.GlassCardView>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <!-- Stat bar -->
                <com.edupulse.teacher.GlassCardView
                    android:id="@+id/statCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/scanned_students"
                                android:textColor="#66FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.15" />

                            <TextView
                                android:id="@+id/scannedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#00E5FF"
                                android:textSize="36sp"
                                android:fontFamily="monospace"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/classSubjectInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#8CFFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>
                </com.edupulse.teacher.GlassCardView>

                <!-- Class & Subject section -->
                <com.edupulse.teacher.GlassCardView
                    android:id="@+id/classSectionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/class_section"
                            android:textColor="#66FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <Spinner
                                android:id="@+id/classSpinner"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_field_glass"
                                android:paddingHorizontal="12dp"
                                android:layout_marginEnd="6dp" />

                            <Spinner
                                android:id="@+id/sectionSpinner"
                                android:layout_width="56dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_field_glass"
                                android:paddingHorizontal="12dp"
                                android:layout_marginStart="6dp"
                                android:layout_marginEnd="6dp" />

                        </LinearLayout>

                        <Spinner
                            android:id="@+id/subjectSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_field_glass"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </com.edupulse.teacher.GlassCardView>

                <!-- Scan button area -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp"
                    android:layout_gravity="center">

                    <Button
                        android:id="@+id/scanButton"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        android:background="@drawable/btn_gradient_scan"
                        android:text="@string/scan_qr"
                        android:textColor="#000000"
                        android:textSize="20sp"
                        android:textAlignment="center"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:elevation="6dp"
                        android:gravity="center" />
                </FrameLayout>

                <!-- Last scanned card -->
                <com.edupulse.teacher.GlassCardView
                    android:id="@+id/lastScannedCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/last_scanned"
                            android:textColor="#66FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/lastScannedPhoto"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/logo_small" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="12dp">

                                <TextView
                                    android:id="@+id/lastScannedName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif" />

                                <TextView
                                    android:id="@+id/lastScannedDetail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#8CFFFFFF"
                                    android:textSize="10sp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.edupulse.teacher.GlassCardView>

                <!-- Scan Finished button -->
                <Button
                    android:id="@+id/scanFinishedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/scan_finished"
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_card_glass"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- === SCAN SUMMARY SHEET === -->
    <LinearLayout
        android:id="@+id/scanSummarySheet"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card_glass"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_gravity="bottom"
        android:elevation="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_summary"
            android:textColor="#66FFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/summaryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#00E5FF"
            android:textSize="36sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/studentRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/addMoreButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/add_more"
                android:textColor="#00E5FF"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_card_glass"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/pushButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/push_to_server"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:background="@drawable/btn_gradient"
                android:stateListAnimator="@null"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- === LOADING OVERLAY === -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/loadingCard"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_card_glass"
            android:padding="24dp"
            android:elevation="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:lottie_rawRes="@raw/loading_spinner"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />

                <TextView
                    android:id="@+id/loadingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/loading_connecting"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/loadingSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- === SUCCESS OVERLAY === -->
    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/successCard"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_card_glass"
            android:padding="24dp"
            android:elevation="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/successAnimation"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp"
                    app:lottie_rawRes="@raw/check"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="false" />

                <TextView
                    android:id="@+id/successTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/success_attendance"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/successSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/successDoneButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/done"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:background="@drawable/btn_gradient"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- === BIOMETRIC OVERLAY === -->
    <FrameLayout
        android:id="@+id/biometricOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone">

        <com.edupulse.teacher.GlassCardView
            android:id="@+id/biometricCard"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="24dp"
            android:elevation="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="🔒"
                    android:textSize="28sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fingerprint_lock"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/biometricStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/usePasswordButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/use_password"
                    android:textColor="#8CFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_card_glass"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </com.edupulse.teacher.GlassCardView>
    </FrameLayout>

    <!-- === UPDATE OVERLAY === -->
    <FrameLayout
        android:id="@+id/updateOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <com.edupulse.teacher.GlassCardView
            android:id="@+id/updateCard"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="20dp"
            android:elevation="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="⬇"
                    android:textColor="#00E5FF"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/update_available"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/updateVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/updateChangelog"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:maxLines="5"
                    android:ellipsize="end" />

                <ProgressBar
                    android:id="@+id/updateProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="#00E5FF"
                    android:visibility="gone"
                    style="?android:attr/progressBarStyleHorizontal" />

                <TextView
                    android:id="@+id/updateProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8CFFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/updateLaterButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/later"
                        android:textColor="#8CFFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_card_glass"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="6dp" />

                    <Button
                        android:id="@+id/updateNowButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/update_now"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:background="@drawable/btn_gradient"
                        android:stateListAnimator="@null"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>
        </com.edupulse.teacher.GlassCardView>
    </FrameLayout>

</FrameLayout>
