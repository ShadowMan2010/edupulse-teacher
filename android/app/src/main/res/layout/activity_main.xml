<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Animated Cyberpunk Background -->
    <com.edupulse.teacher.CyberBgView
        android:id="@+id/cyberBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ═══════════════════════ SPLASH SCREEN ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/splashContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="visible">

        <com.edupulse.teacher.MatrixRainView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.25"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:id="@+id/splashLogo"
                android:contentDescription="Logo"/>

            <com.edupulse.teacher.GlitchTextView
                android:id="@+id/splashTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDUPULSE"
                android:textSize="28sp"
                android:textColor="#00E5FF"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher"
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.2"
                android:layout_marginTop="4dp"/>

            <com.edupulse.teacher.DigitalLoader
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="40dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════ LOGIN SCREEN ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/loginContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <com.edupulse.teacher.MatrixRainView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.2"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="32dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:layout_marginTop="48dp"/>

                <com.edupulse.teacher.GlitchTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EDUPULSE"
                    android:textSize="24sp"
                    android:textColor="#00E5FF"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher Sign In"
                    android:textSize="16sp"
                    android:textColor="#9E9E9E"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="36dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="24dp"
                    android:layout_marginTop="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.EduPulse.TextInput"
                    app:hintEnabled="true"
                    app:endIconMode="clear_text">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:textColor="#E0E0E0"
                        android:fontFamily="sans-serif"/>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.EduPulse.TextInput"
                    app:hintEnabled="true"
                    app:endIconMode="password_toggle"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textColor="#E0E0E0"
                        android:fontFamily="sans-serif"/>

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="SIGN IN"
                    android:textAllCaps="true"
                    android:textSize="14sp"
                    style="@style/Widget.EduPulse.Button"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="or"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"/>

                <com.google.android.gms.common.SignInButton
                    android:id="@+id/googleSignInButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/loginError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#FF3B3B"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:visibility="gone"/>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- ═══════════════════════ CONNECT SCREEN ═══════════════════════ -->
    <ScrollView
        android:id="@+id/connectContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:layout_marginTop="48dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect to Server"
                android:textSize="22sp"
                android:textColor="#E0E0E0"
                android:fontFamily="sans-serif"
                android:layout_marginTop="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the server IP address"
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                style="@style/Widget.EduPulse.TextInput"
                app:hintEnabled="true"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/connectIp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Server IP (e.g. 192.168.1.100)"
                    android:inputType="text"
                    android:textColor="#E0E0E0"
                    android:fontFamily="monospace"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                style="@style/Widget.EduPulse.TextInput"
                app:hintEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/connectPort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Port"
                    android:inputType="number"
                    android:text="3000"
                    android:textColor="#E0E0E0"
                    android:fontFamily="monospace"/>

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="CONNECT"
                android:textAllCaps="true"
                android:textSize="14sp"
                style="@style/Widget.EduPulse.Button"/>

            <TextView
                android:id="@+id/connectStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:gravity="center"/>

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════ MAIN SCREEN ═══════════════════════ -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EduPulse"
                android:textSize="15sp"
                android:textColor="#00E5FF"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/userEmailText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Exit"
                android:textSize="10sp"
                android:backgroundTint="#FF3B3B"
                android:textColor="#fff"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:fontFamily="monospace"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <!-- Scan Count Bar -->
        <LinearLayout
            android:id="@+id/scanCountBar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_stat_card"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCANNED STUDENTS"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:id="@+id/scanCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="36sp"
                    android:textColor="#00E5FF"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/scanInfoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:gravity="end"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLASS &amp; SUBJECT"
            android:textSize="10sp"
            android:textColor="#00E5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLASS"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/classSpinner"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:popupBackground="#111111"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEC"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/sectionSpinner"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="0.5"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:popupBackground="#111111"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUBJECT"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/subjectSpinner"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:popupBackground="#111111"/>
        </LinearLayout>

        <!-- Scan Button with Pulse Ring -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp">

            <com.edupulse.teacher.ScanPulseView
                android:layout_width="200dp"
                android:layout_height="200dp"/>

            <Button
                android:id="@+id/scanButton"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/btn_gradient_scan"
                android:text="SCAN\nQR"
                android:textSize="20sp"
                android:textColor="#000000"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:stateListAnimator="@null"
                android:elevation="8dp"
                android:translationZ="12dp"/>
        </FrameLayout>

        <!-- Latest Scan Info -->
        <LinearLayout
            android:id="@+id/lastScannedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/lastScannedText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#E0E0E0"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <!-- Scan Finished Button -->
        <Button
            android:id="@+id/scanFinishedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:text="SCAN FINISHED"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:visibility="gone"
            style="@style/Widget.EduPulse.Button.Outline"/>

    </LinearLayout>

    <!-- ═══════════════════════ LOADING OVERLAY ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="32dp"
            android:elevation="8dp">

            <com.edupulse.teacher.DigitalLoader
                android:layout_width="72dp"
                android:layout_height="72dp"/>

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecting..."
                android:textSize="14sp"
                android:textColor="#00E5FF"
                android:fontFamily="monospace"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/loadingSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp"
                android:gravity="center"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════ SCAN SUMMARY SHEET ═══════════════════════ -->
    <LinearLayout
        android:id="@+id/scanSummarySheet"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:visibility="gone"
        android:elevation="16dp"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCAN SUMMARY"
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"/>

        <TextView
            android:id="@+id/summaryCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 students scanned"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:fontFamily="sans-serif"
            android:layout_marginTop="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/summaryList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/addMoreButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="ADD MORE"
                android:textSize="12sp"
                style="@style/Widget.EduPulse.Button.Outline"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/pushButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="PUSH TO SERVER"
                android:textSize="12sp"
                style="@style/Widget.EduPulse.Button"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════ SUCCESS OVERLAY ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <com.edupulse.teacher.ConfettiView
            android:id="@+id/confettiView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="36dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/successIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="✓"
                android:textSize="40sp"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/bg_success_circle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attendance Pushed!"
                android:textSize="20sp"
                android:textColor="#E0E0E0"
                android:fontFamily="monospace"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/successSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif"
                android:layout_marginTop="6dp"
                android:gravity="center"/>

            <Button
                android:id="@+id/successDoneButton"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:text="DONE"
                android:textSize="13sp"
                style="@style/Widget.EduPulse.Button"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════ BIOMETRIC LOCK ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/biometricOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="16dp"
            android:padding="36dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="🔒"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_success_circle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FINGERPRINT LOCK"
                android:textSize="18sp"
                android:textColor="#E0E0E0"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/biometricStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Touch the fingerprint sensor"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/biometricUsePasswordButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="24dp"
                android:text="USE PASSWORD"
                android:textSize="12sp"
                style="@style/Widget.EduPulse.Button.Outline"/>

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════ UPDATE OVERLAY ═══════════════════════ -->
    <FrameLayout
        android:id="@+id/updateOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="16dp"
            android:padding="28dp">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="⬇"
                android:textSize="26sp"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/bg_success_circle"/>

            <TextView
                android:id="@+id/updateTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update Available"
                android:textSize="18sp"
                android:textColor="#E0E0E0"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/updateVersionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v2.0.0"
                android:textSize="13sp"
                android:textColor="#00E5FF"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/updateChangelogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:layout_marginTop="14dp"
                android:maxLines="8"
                android:ellipsize="end"/>

            <ProgressBar
                android:id="@+id/updateProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="16dp"
                android:progressTint="#00E5FF"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/updateProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/updateButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="UPDATE NOW"
                android:textSize="13sp"
                style="@style/Widget.EduPulse.Button"/>

            <Button
                android:id="@+id/updateLaterButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="LATER"
                android:textSize="12sp"
                style="@style/Widget.EduPulse.Button.Outline"/>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>