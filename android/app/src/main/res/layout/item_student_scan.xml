<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="#111113"
    android:padding="8dp"
    android:layout_marginBottom="4dp">

    <ImageView
        android:id="@+id/studentPhoto"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:background="#1a1a1e"
        android:visibility="visible"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/studentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#f8fafc"
            android:fontFamily="@font/inter_medium"
            android:singleLine="true"/>

        <TextView
            android:id="@+id/studentDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#94a3b8"
            android:fontFamily="@font/jetbrainsmono_regular"
            android:singleLine="true"/>

    </LinearLayout>

    <TextView
        android:id="@+id/statusBadge"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:textSize="9sp"
        android:gravity="center"
        android:background="@drawable/bg_badge_pill"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/removeButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="✕"
        android:textSize="14sp"
        android:textColor="#ef4444"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
