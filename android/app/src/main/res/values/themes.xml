<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EduPulse" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#00ffff</item>
        <item name="colorPrimaryVariant">#00cccc</item>
        <item name="colorOnPrimary">#0a0a0b</item>
        <item name="colorSecondary">#00ffff</item>
        <item name="colorSecondaryVariant">#00cccc</item>
        <item name="colorOnSecondary">#0a0a0b</item>
        <item name="android:colorBackground">#0a0a0b</item>
        <item name="colorSurface">#111113</item>
        <item name="colorOnSurface">#f8fafc</item>
        <item name="android:statusBarColor">#0a0a0b</item>
        <item name="android:navigationBarColor">#0a0a0b</item>
    </style>

    <style name="Widget.EduPulse.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#00ffff</item>
        <item name="android:textColor">#0a0a0b</item>
        <item name="android:textAllCaps">true</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.EduPulse.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">#00ffff</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">#00ffff</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.EduPulse.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#00ffff</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">#94a3b8</item>
    </style>
</resources>
