{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "schools": {
      "$schoolId": {
        ".read": true,
        ".write": true,
        "attendance": {
          ".indexOn": ["date"]
        }
      }
    },
    "schoolId": {
      ".read": true,
      ".write": true
    },
    "subjects": {
      ".read": true,
      ".write": "auth != null"
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pending_registrations": {
      ".read": true,
      ".write": true
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "teachers": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
