{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "students": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "attendance": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    }
  }
}
